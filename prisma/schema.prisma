generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleCode {
  ADMIN
  COLLABORATOR
  APPROVER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum CollaboratorStatus {
  ACTIVE
  INACTIVE
}

enum QuotaStatus {
  ACTIVE
  ADJUSTED
  CANCELLED
}

enum ExpenseCategory {
  FUEL
  MAINTENANCE
}

enum ExpenseStatus {
  ACTIVE
  VOIDED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ASSIGN_QUOTA
  REGISTER_EXPENSE
  UPDATE_EXPENSE
  DELETE_EXPENSE
  RECALCULATE_BALANCE
  QUERY_BALANCE
}

enum EntityType {
  USER
  COLLABORATOR
  MONTHLY_QUOTA
  EXPENSE
  MONTHLY_BALANCE
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  fullName          String
  role              RoleCode
  status            UserStatus     @default(ACTIVE)
  passwordHash      String?
  mustChangePassword Boolean       @default(false)
  lastLoginAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  collaborator      Collaborator?
  assignedQuotas    MonthlyQuota[] @relation("QuotaAssignedBy")
  quotaUpdates      MonthlyQuota[] @relation("QuotaUpdatedBy")
  registeredExpenses Expense[]     @relation("ExpenseRegisteredBy")
  updatedExpenses   Expense[]      @relation("ExpenseUpdatedBy")
  voidedExpenses    Expense[]      @relation("ExpenseVoidedBy")
  auditLogs         AuditLog[]     @relation("AuditActor")

  @@index([role])
  @@index([status])
}

model Collaborator {
  id               String             @id @default(cuid())
  employeeId       String             @unique
  documentNumber   String?
  fullName         String
  costCenter       String?
  department       String?
  vehicleReference String?
  userId           String?            @unique
  status           CollaboratorStatus @default(ACTIVE)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user             User?              @relation(fields: [userId], references: [id])
  monthlyQuotas    MonthlyQuota[]
  expenses         Expense[]
  monthlyBalances  MonthlyBalance[]

  @@index([status])
  @@index([costCenter])
}

model MonthlyQuota {
  id              String      @id @default(cuid())
  collaboratorId  String
  year            Int
  // Valid range is enforced in business logic: 1..12
  month           Int
  amount          Decimal     @db.Decimal(12, 2)
  currency        String      @default("USD")
  assignedByUserId String
  updatedByUserId String?
  status          QuotaStatus @default(ACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  collaborator    Collaborator @relation(fields: [collaboratorId], references: [id])
  assignedBy      User         @relation("QuotaAssignedBy", fields: [assignedByUserId], references: [id])
  updatedBy       User?        @relation("QuotaUpdatedBy", fields: [updatedByUserId], references: [id])

  @@unique([collaboratorId, year, month])
  @@index([year, month])
  @@index([assignedByUserId])
  @@index([status])
}

model Expense {
  id                String          @id @default(cuid())
  collaboratorId    String
  expenseDate       DateTime
  year              Int
  // Valid range is enforced in business logic: 1..12
  month             Int
  category          ExpenseCategory
  amount            Decimal         @db.Decimal(12, 2)
  currency          String          @default("USD")
  description       String?
  registeredByUserId String
  updatedByUserId   String?
  voidedByUserId    String?
  voidedAt          DateTime?
  status            ExpenseStatus   @default(ACTIVE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  collaborator      Collaborator    @relation(fields: [collaboratorId], references: [id])
  registeredBy      User            @relation("ExpenseRegisteredBy", fields: [registeredByUserId], references: [id])
  updatedBy         User?           @relation("ExpenseUpdatedBy", fields: [updatedByUserId], references: [id])
  voidedBy          User?           @relation("ExpenseVoidedBy", fields: [voidedByUserId], references: [id])

  @@index([collaboratorId])
  @@index([collaboratorId, year, month])
  @@index([expenseDate])
  @@index([category])
  @@index([registeredByUserId])
  @@index([voidedByUserId])
  @@index([status])
}

model MonthlyBalance {
  id                 String       @id @default(cuid())
  collaboratorId     String
  year               Int
  // Valid range is enforced in business logic: 1..12
  month              Int
  openingBalance     Decimal      @db.Decimal(12, 2)
  quotaAmount        Decimal      @db.Decimal(12, 2)
  executedAmount     Decimal      @db.Decimal(12, 2)
  closingBalance     Decimal      @db.Decimal(12, 2)
  currency           String       @default("USD")
  lastExpenseDate    DateTime?
  calculationVersion Int          @default(1)
  recalculatedAt     DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  collaborator       Collaborator @relation(fields: [collaboratorId], references: [id])

  @@unique([collaboratorId, year, month])
  @@index([year, month])
  @@index([closingBalance])
  @@index([recalculatedAt])
}

model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String
  actorRole   RoleCode
  action      AuditAction
  entityType  EntityType
  entityId    String
  reason      String?
  beforeValue Json?
  afterValue  Json?
  metadata    Json?
  createdAt   DateTime    @default(now())

  actor       User        @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([entityType])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action])
}
